{
  "productName": "BL4CK Viewer",
  "version": "0.13.14",
  "identifier": "com.breeze.viewer",
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http: wss: ws: ipc://localhost; img-src 'self' blob: data:; style-src 'self'"
    },
    "windows": [
      {
        "title": "BL4CK Remote Desktop",
        "width": 500,
        "height": 340,
        "resizable": false,
        "fullscreen": false,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["breeze"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM5RTExMzM0MEQ1ODA3QUQKUldTdEIxZ05OQlBoT1dOK1hYQ1F0Sys0ckppTnZWV0RUUEF0aEZtYXgzMlB6RXRXaUNBMTkwbXAK",
      "endpoints": [
        "https://github.com/LanternOps/breeze/releases/latest/download/latest.json"
      ]
    }
  }
}
