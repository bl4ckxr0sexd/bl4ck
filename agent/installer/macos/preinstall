#!/bin/bash
# BL4CK Agent macOS .pkg preinstall script
# Stops the existing agent service before files are replaced.

# Stop watchdog
launchctl bootout system/com.bl4ck.watchdog 2>/dev/null || true

# Stop existing daemon gracefully
launchctl bootout system/com.bl4ck.agent 2>/dev/null || true

# Unload legacy-style if bootout fails (older macOS)
if [ -f /Library/LaunchDaemons/com.bl4ck.agent.plist ]; then
    launchctl unload /Library/LaunchDaemons/com.bl4ck.agent.plist 2>/dev/null || true
fi

# Stop existing user helper for all logged-in GUI users
for uid in $(ps -axo uid= -o comm= | grep -i '[lL]oginwindow' | awk '{print $1}' | sort -u); do
    [ "$uid" = "0" ] && continue
    launchctl bootout "gui/$uid/com.bl4ck.agent-user" 2>/dev/null || true
done

exit 0
