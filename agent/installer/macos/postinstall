#!/bin/bash
# BL4CK Agent macOS .pkg postinstall script
# Runs as root after the installer places files on disk.

set -e

BINARY="/usr/local/bin/bl4ck-agent"
DESKTOP_HELPER_BINARY="/usr/local/bin/bl4ck-desktop-helper"
CONFIG_DIR="/Library/Application Support/BL4CK"
LOG_DIR="/Library/Logs/BL4CK"
DAEMON_PLIST="/Library/LaunchDaemons/com.bl4ck.agent.plist"
DESKTOP_USER_PLIST="/Library/LaunchAgents/com.bl4ck.desktop-helper-user.plist"
DESKTOP_LOGINWINDOW_PLIST="/Library/LaunchAgents/com.bl4ck.desktop-helper-loginwindow.plist"

ensure_breeze_group() {
    if dscl . -read /Groups/breeze &>/dev/null; then
        dscl . -read /Groups/breeze PrimaryGroupID &>/dev/null
        return
    fi

    gid=350
    while [ "$gid" -le 499 ]; do
        if ! dscl . -list /Groups PrimaryGroupID 2>/dev/null | awk '{print $2}' | grep -qx "$gid"; then
            dscl . -create /Groups/breeze
            dscl . -create /Groups/breeze PrimaryGroupID "$gid"
            return
        fi
        gid=$((gid + 1))
    done

    echo "No free local system GID available for breeze group" >&2
    exit 1
}

# Create directories
mkdir -p "$CONFIG_DIR"
chmod 0700 "$CONFIG_DIR"
mkdir -p "$LOG_DIR"
chmod 0755 "$LOG_DIR"

# Remove quarantine attribute (binary is notarized but raw
# Mach-O binaries cannot have the ticket stapled)
xattr -d com.apple.quarantine "$BINARY" 2>/dev/null || true
xattr -d com.apple.quarantine "$DESKTOP_HELPER_BINARY" 2>/dev/null || true

# Set permissions
chmod 0755 "$BINARY"
chmod 0755 "$DESKTOP_HELPER_BINARY"
chmod 0644 "$DAEMON_PLIST"
chmod 0644 "$DESKTOP_USER_PLIST"
chmod 0644 "$DESKTOP_LOGINWINDOW_PLIST"

# Watchdog
WATCHDOG_BINARY="/usr/local/bin/bl4ck-watchdog"
if [ -f "$WATCHDOG_BINARY" ]; then
    xattr -d com.apple.quarantine "$WATCHDOG_BINARY" 2>/dev/null || true
    chmod 0755 "$WATCHDOG_BINARY"
fi

# Bootstrap watchdog daemon
WATCHDOG_PLIST="/Library/LaunchDaemons/com.bl4ck.watchdog.plist"
if [ -f "$WATCHDOG_PLIST" ]; then
    launchctl bootout system/com.bl4ck.watchdog 2>/dev/null || true
    launchctl bootstrap system "$WATCHDOG_PLIST" 2>/dev/null || \
        launchctl load "$WATCHDOG_PLIST" 2>/dev/null || true
fi

# Create breeze group for IPC socket access.
ensure_breeze_group

# Stop existing service if running
launchctl bootout system/com.bl4ck.agent 2>/dev/null || true

# Load the daemon (starts automatically via RunAtLoad)
launchctl bootstrap system "$DAEMON_PLIST"

# Load the user helper LaunchAgent for all currently logged-in GUI users.
# The plist lives in /Library/LaunchAgents/ so launchd will auto-load it
# for future logins, but we need to bootstrap it now for anyone already
# logged in so Remote Desktop works immediately after install.
for uid in $(ps -axo uid= -o comm= | grep -i '[lL]oginwindow' | awk '{print $1}' | sort -u); do
    # Skip root (uid 0) — LaunchAgents are user-session only
    [ "$uid" = "0" ] && continue
    # Unload any stale instance first
    launchctl bootout "gui/$uid/com.bl4ck.desktop-helper-user" 2>/dev/null || true
    # Bootstrap into the user's GUI domain
    launchctl bootstrap "gui/$uid" "$DESKTOP_USER_PLIST" 2>/dev/null || true
done

launchctl bootstrap loginwindow "$DESKTOP_LOGINWINDOW_PLIST" 2>/dev/null || true

echo "BL4CK Agent installed and started."
exit 0
